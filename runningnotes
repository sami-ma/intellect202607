Constraints:

create table dept (dno int primary key, dname varchar(10) not null);

create table employee (
empno int primary key,
ename varchar(25) not null,
pan_no varchar(10) unique,
salary decimal(10,2) check (salary > 0),
deptno int references dept(dno)
);

Queries on Employee and department tables:

select * from emp;
select * from dept;
select * from salgrade;

select ename, job, sal from emp;
select sal, job from emp;
select * from emp;
select * from emp order by ename desc;
select * from emp order by ename;
select ename, job, sal from emp order by sal desc;
select ename, job, sal from emp order by sal desc, ename desc;
select * from emp limit 3;
select * from emp order by sal desc limit 3;
select ename, job from emp;
select ename, job from emp limit 2 offset 4;

select * from emp where ename = 'JONES';
select * from emp where ename in ('JONES', 'ALLEN');
select * from emp where ename like 'S%';
select * from emp where ename not like 'S%';

select * from emp where ename ~~ 'S%';
select * from emp where ename !~~ 'S%';

select job from emp;
select distinct job from emp;
select ename as "Employee Name", job as Designation from emp;
select ename as "Employee Name", job designation from emp;
select * from emp where ename = $$JONES$$;
-- date arithmetic
select now();
select now() + interval '10 days';
-- type casting
select date '2026-07-25' + interval '15 days';
select '2026-07-25'::date + interval '15 days';
-- to_char
select ename, job, to_char(hiredate, 'DAY') from emp;
select ename, job, to_char(hiredate, 'DY'), to_char(hiredate, 'MONTH') from emp;

-- aggregate function and group OPERATIONS

select sum(sal) from emp;
select avg(sal) from emp;
select min(sal), max(sal), count(*) from emp;

select job, min(sal), max(sal), count(*) from emp group by job;

select job, min(sal), max(sal), count(*) from emp group by job having count(*) >= 3;

select job, min(sal), max(sal), count(*), string_agg(ename, ',') from emp group by job;


-- inner join 
select  ename, job, sal, dname from emp join dept on emp.deptno = dept.deptno ;
-- inner join and table aliases are used.
select  ename, job, sal, dname from emp e join dept d on e.deptno = d.deptno ;
-- inner join with inner key word
select  ename, job, sal, dname from emp e inner join dept d on e.deptno = d.deptno ;
-- Outer Join

select  ename, job, sal, dname from emp e right outer join  dept d on e.deptno = d.deptno ;
--full outer join
select  ename, job, sal, dname from emp e full outer join  dept d on e.deptno = d.deptno ;

-- natural join
select  ename, job, sal, dname from emp e natural join dept d;

-- self join

select e.ename as "Employee Name", m.ename as "Manager Name" from emp e join emp m on e.mgr = m.empno;

-- non equi joins
select e.ename, e.job, e.sal, s.grade from emp e join salgrade s on e.sal between s.losal and s.hisal;


-- join 3 tables

select e.ename, e.job, e.sal, s.grade, d.dname from emp e join salgrade s on e.sal between s.losal and s.hisal join dept d on e.deptno = d.deptno  ;

-- sub queries

select * from emp where sal = (select max(sal) from emp);

-- multi valued subquery

select * from emp where deptno in (select deptno from dept where loc in ('DALLAS', 'CHICAGO'));

-- co-related sub subquery
select * from emp e1  where e1.sal = (select max(e2.sal) from emp e2 where e2.job = e1.job);


